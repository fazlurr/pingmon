{
  "name": "ping-monitor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create ping-monitor-db",
    "db:migrate": "wrangler d1 execute ping-monitor-db --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute ping-monitor-db --remote --file=migrations/0001_init.sql"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}
