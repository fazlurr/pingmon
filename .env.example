# ──────────────────────────────────────────────
# pingmon — environment configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# Required: Cloudflare Worker URL (no trailing slash)
REPORT_URL=https://pingmon.YOUR_SUBDOMAIN.workers.dev

# Optional overrides (defaults shown)
TARGET=google.com
INTERVAL=60
PING_INTERVAL=1
SPIKE_THRESHOLD=20
WARN_AVG_ABOVE=10
