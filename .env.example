# ──────────────────────────────────────────────
# ping_monitor — environment configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# Required: Cloudflare Worker URL (no trailing slash)
REPORT_URL=https://ping-monitor.YOUR_SUBDOMAIN.workers.dev

# Optional overrides (defaults shown)
TARGET=google.com
INTERVAL=60
PING_INTERVAL=2
SPIKE_THRESHOLD=50
WARN_AVG_ABOVE=10
